# Wallet that deploys the contract and pays Tempo gas (in pathUSD).
DEPLOYER_PRIVATE_KEY=
# Optional: the address allowed to anchor (defaults to the deployer).
ISSUER_ADDRESS=

# Optional RPC overrides (defaults are the public Tempo endpoints).
TEMPO_TESTNET_RPC=https://rpc.moderato.tempo.xyz
TEMPO_MAINNET_RPC=https://rpc.tempo.xyz
